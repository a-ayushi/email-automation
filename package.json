{
  "name": "email-outreach",
  "version": "1.0.0",
  "description": "Automated personalized AI-powered email outreach using Claude",
  "main": "dist/backend/server.js",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "build": "npm run build:backend",
    "build:backend": "tsc",
    "build:frontend": "vite build",
    "build:all": "npm run build:backend && npm run build:frontend",
    "start": "node dist/backend/server.js",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "ts-node src/backend/server.ts",
    "dev:frontend": "vite --host",
    "preview": "vite preview",
    "test": "echo \"Error: no test specified\" && exit 1",
    "render-build": "npm ci --no-audit --no-fund && npm run build:backend"
  },
  "dependencies": {
    "@google/generative-ai": "^0.3.0",
    "@hookform/resolvers": "^3.3.0",
    "axios": "^1.6.0",
    "better-sqlite3": "^11.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.18.2",
    "imap": "^0.8.19",
    "lucide-react": "^0.294.0",
    "mailparser": "^3.7.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.0",
    "openai": "^4.104.0",
    "papaparse": "^5.4.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.48.0",
    "react-router-dom": "^6.20.0",
    "recharts": "^2.10.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.9",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/imap": "^0.8.40",
    "@types/mailparser": "^3.4.4",
    "@types/node": "^20.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.14",
    "@types/papaparse": "^5.3.14",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "date-fns": "^4.1.0",
    "postcss": "^8.4.32",
    "rollup": "^4.60.0",
    "tailwindcss": "^3.3.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0",
    "vite": "^5.0.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.60.0"
  }
}
